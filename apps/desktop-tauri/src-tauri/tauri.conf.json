{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HotSAS Studio",
  "version": "0.1.0",
  "identifier": "studio.hotsas.desktop",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "beforeBuildCommand": "npm.cmd run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HotSAS Studio",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
